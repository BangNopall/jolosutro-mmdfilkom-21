# Supabase — dapatkan dari dashboard Supabase project Anda
# https://supabase.com/dashboard/project/<project-id>/settings/api

# Server-side (tidak diekspos ke browser)
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_PUBLISHABLE_KEY=<your-publishable-key>

# Client-side (diekspos ke browser via Vite — OK untuk publishable key)
VITE_SUPABASE_URL=https://<project-id>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<your-publishable-key>

# Opsional — hanya untuk Supabase local dev
# SUPABASE_PROJECT_ID=<project-id>
# VITE_SUPABASE_PROJECT_ID=<project-id>
